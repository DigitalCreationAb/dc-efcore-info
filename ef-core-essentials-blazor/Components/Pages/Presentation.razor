@page "/presentation"
@rendermode InteractiveServer
@inject IJSRuntime JS
@implements IAsyncDisposable
@using ef_core_essentials_blazor.Components.Pages.Slides

<div class="pres-root">

    <header class="pres-header">
        <div class="pres-logo">DC</div>
        <div class="pres-header-title">EF Core Essentials &mdash; .NET 10</div>
        @if (_slide > 0)
        {
            <span class="pres-chapter-label">@_chapters[_slide]</span>
        }
        <div class="pres-nav">
            <button class="pres-btn" @onclick="Prev" disabled="@(_slide == 0)" title="Previous (?)">&#8592;</button>
            <span class="pres-counter">@(_slide + 1)&thinsp;/&thinsp;@TotalSlides</span>
            <button class="pres-btn" @onclick="Next" disabled="@(_slide == TotalSlides - 1)" title="Next (?)">&#8594;</button>
        </div>
    </header>

    <main class="pres-main">
        @switch (_slide)
        {
            case  0: <Slide00Title /> break;
            case  1: <Slide01WhyNotRepository /> break;
            case  2: <Slide02IQueryable /> break;
            case  3: <Slide03Select /> break;
            case  4: <Slide04ExtensionMethods /> break;
            case  5: <Slide05ToPaging /> break;
            case  6: <Slide06GlobalFilters /> break;
            case  7: <Slide08CompiledQueries /> break;
            case  8: <Slide09JsonColumns /> break;
            case  9: <Slide10AsyncEnumerable /> break;
            case 10: <Slide11BulkOperations /> break;
            case 11: <Slide12Comparison /> break;
            case 12: <Slide13Summary /> break;
        }
    </main>

    <div class="pres-progress">
        <div class="pres-progress-fill" style="width: @((_slide + 1.0) / TotalSlides * 100.0)%"></div>
    </div>

    <footer class="pres-footer">
        @for (int i = 0; i < TotalSlides; i++)
        {
            var idx = i;
            <button class="pres-dot @(idx == _slide ? "pres-dot--active" : "")"
                    @onclick="() => GoTo(idx)"
                    title="Slide @(idx + 1)"></button>
        }
    </footer>

</div>

@code {
    private int _slide = 0;
    private const int TotalSlides = 13;
    private DotNetObjectReference<Presentation>? _ref;
    private IJSObjectReference? _module;

    private static readonly string[] _chapters =
    [
        "",
        "Chapter 1 · Foundations",
        "Chapter 1 · Foundations",
        "Chapter 2 · Data Access Patterns",
        "Chapter 2 · Data Access Patterns",
        "Chapter 2 · Data Access Patterns",
        "Chapter 3 · Automatic Behaviors",
        "Chapter 4 · Advanced EF Core",
        "Chapter 4 · Advanced EF Core",
        "Chapter 4 · Advanced EF Core",
        "Chapter 4 · Advanced EF Core",
        "Chapter 5 · Comparison",
        "Summary",
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _ref = DotNetObjectReference.Create(this);
        // JS module isolation: import() loads the file on-demand at the right moment,
        // avoiding the timing issue where HeadContent scripts aren't yet executed.
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/presentation.js");
        await _module.InvokeVoidAsync("init", _ref);
    }

    [JSInvokable]
    public void HandleKey(string dir)
    {
        if (dir == "next") Next();
        else Prev();
        StateHasChanged();
    }

    private void Next() { if (_slide < TotalSlides - 1) _slide++; }
    private void Prev() { if (_slide > 0) _slide--; }
    private void GoTo(int idx) { _slide = idx; }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module != null)
            {
                await _module.InvokeVoidAsync("dispose");
                await _module.DisposeAsync();
            }
        }
        catch { }
        _ref?.Dispose();
    }
}

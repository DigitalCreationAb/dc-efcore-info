    <h1 class="slide-h"><code>AsAsyncEnumerable</code> &mdash; Constant Memory Streaming</h1>
    <p class="slide-p"><code>ToListAsync</code> waits for all rows, then returns. <code>AsAsyncEnumerable</code> yields each row as it arrives &mdash; memory stays constant and the first row appears immediately.</p>

    <div class="slide-grid-2">
        <pre class="code"><code><span class="cm">// [EnumeratorCancellation] propagates the token</span>
<span class="cm">// into .WithCancellation() on the DB cursor</span>
<span class="kw">public async</span> <span class="tp">IAsyncEnumerable</span>&lt;<span class="tp">ProductListDto</span>&gt; <span class="mt">StreamProductsAsync</span>(
    [<span class="tp">EnumeratorCancellation</span>] <span class="tp">CancellationToken</span> ct = <span class="kw">default</span>)
{
    <span class="kw">await foreach</span> (<span class="kw">var</span> p <span class="kw">in</span> ctx.Products
        .<span class="mt">OrderBy</span>(p =&gt; p.Id)
        .<span class="mt">Select</span>(p =&gt; <span class="kw">new</span> <span class="tp">ProductListDto</span> {...})
        .<span class="mt">AsAsyncEnumerable</span>()
        .<span class="mt">WithCancellation</span>(ct)) <span class="cm">// cancels DB cursor</span>
    {
        <span class="kw">yield return</span> p;     <span class="cm">// caller gets rows immediately</span>
    }
}

<span class="cm">// Blazor Server — live UI updates per row</span>
<span class="kw">await foreach</span> (<span class="kw">var</span> p <span class="kw">in</span> svc.<span class="mt">StreamProductsAsync</span>(cts.Token))
{
    _rows.<span class="mt">Add</span>(p);
    _total += p.Price;
    <span class="kw">await</span> <span class="mt">InvokeAsync</span>(StateHasChanged); <span class="cm">// live counter</span>
}</code></pre>

